# Normalize line endings: 仓库内统一用 LF，无论 checkout 平台
# 避免 Windows (CRLF) 与 Linux/macOS (LF) 互相冲突
* text=auto eol=lf

# 明确二进制文件，不做行尾转换
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.lockb binary

# Windows 专用脚本保持 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Unix 脚本保持 LF
*.sh text eol=lf
