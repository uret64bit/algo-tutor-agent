# PostgreSQL
POSTGRES_USER=algo_tutor
POSTGRES_PASSWORD=algo_tutor_secret
POSTGRES_DB=algo_tutor
DATABASE_URL=postgresql+asyncpg://algo_tutor:algo_tutor_secret@postgres:5432/algo_tutor

# Backend
JWT_SECRET=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Redis
REDIS_URL=redis://redis:6379/0

# OpenAI / Agent
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_REQUEST_TIMEOUT_SEC=30.0
AGENT_MAX_TOOL_ROUNDS=5
AGENT_REQUEST_TIMEOUT_SEC=60.0

# 代码执行沙箱
SANDBOX_IMAGE=algo-sandbox:latest
SANDBOX_NETWORK_DISABLED=true
SANDBOX_CPU_LIMIT=1.0
SANDBOX_MEMORY_LIMIT_MB=256
SANDBOX_PIDS_LIMIT=64
SANDBOX_DEFAULT_TIMEOUT_MS=3000
SANDBOX_MAX_TIMEOUT_MS=5000
SANDBOX_MAX_MEMORY_MB=512
SANDBOX_MAX_OUTPUT_BYTES=16384
SANDBOX_USER=sandbox

# 检索 / RAG
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_DIM=1536
RAG_DEFAULT_LIMIT=5
RAG_MAX_LIMIT=10

# CORS（list[str] 类型，JSON 数组需用单引号包裹避免被 docker 解析掉方括号）
CORS_ORIGINS='["http://localhost:5173"]'
